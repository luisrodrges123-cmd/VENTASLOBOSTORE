<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Futuristic Base Theme -->
    <style name="Base.Theme.VENTASLOBOSTORE" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Main Colors -->
        <item name="colorPrimary">@color/neon_cyan</item>
        <item name="colorSecondary">@color/neon_purple</item>
        <item name="android:windowBackground">@color/deep_space_black</item>

        <!-- Status Bar & Navigation -->
        <item name="android:statusBarColor">@color/deep_space_black</item>
        <item name="android:navigationBarColor">@color/deep_space_black</item>

        <!-- Typography -->
        <item name="android:textColorPrimary">@color/text_high_emphasis</item>
        <item name="android:textColorSecondary">@color/text_medium_emphasis</item>

        <!-- Shape Appearance (Futuristic/Sharp) -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.Futuristic.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.Futuristic.Medium</item>
    </style>

    <style name="Theme.VENTASLOBOSTORE" parent="Base.Theme.VENTASLOBOSTORE" />

    <!-- Futuristic Shapes -->
    <style name="ShapeAppearance.Futuristic.Small" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">cut</item>
        <item name="cornerSize">4dp</item>
    </style>

    <style name="ShapeAppearance.Futuristic.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <!-- Glassmorphism Card Style -->
    <style name="Widget.VENTASLOBOSTORE.GlassCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/dark_glass</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">#33FFFFFF</item>
        <item name="strokeWidth">1dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Futuristic.Medium</item>
    </style>
    <!-- Premium Dialog Style -->
    <style name="Theme.VENTASLOBOSTORE.Dialog" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:windowBackground">@color/deep_space_black</item>
        <item name="android:textColorPrimary">@color/neon_cyan</item>
        <item name="android:textColorSecondary">@color/text_medium_emphasis</item>
        <item name="colorAccent">@color/neon_purple</item>
    </style>
</resources>
